# Supabase — côté client (exposées au navigateur, OK pour anon key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — côté serveur UNIQUEMENT (ne jamais exposer au navigateur)
# Utilisée pour les opérations admin (migrations, scripts). Ne pas committer.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
